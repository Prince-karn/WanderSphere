<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <div class="col-8 offset-3">
        <h3><%= listing.title %></h3>
    </div>
   
    <!-- Listing Card -->
    <div class="card col-6 offset-3 show-card listing-card">
        <img src="<%= listing.image?.url || '/default.jpg' %>" 
             class="card-img-top show-img" 
             alt="<%= listing.title %>">

        <div class="card-body">

            <p class="card-text">
                <i>Owned by: <%= listing.owner?.username || "Anonymous" %></i>
            </p>

            <p class="card-text"><%= listing.description %></p>
            <p class="card-text">&#8377;<%= listing.price?.toLocaleString("en-IN") || "0" %></p>
            <p class="card-text"><%= listing.location %>, <%= listing.country %></p>
        </div>
    </div>      
</div>


<!-- Edit/Delete Buttons -->
<% if(currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
    <div class="show-btns">
        <a href="/listings/<%= listing._id %>/edit" 
           class="btn btn-dark col-1 offset-3 edit-btn">Edit</a>

        <form method="POST" 
              action="/listings/<%= listing._id %>?_method=DELETE" 
              class="d-inline">
            <button class="btn btn-dark offset-5">Delete</button>
        </form>
    </div>
<% } %>


<!-- Reviews Section -->
<div class="col-8 offset-3 mb-3">
    <hr>

    <!-- Review Form -->
    <% if(currentUser) { %>
        <h4>Leave a Review</h4>

        <form action="/listings/<%= listing._id %>/reviews" 
              method="POST" 
              novalidate 
              class="needs-validation">

            <!-- Rating -->
            <div class="mb-3 mt-3">
                <label class="form-label">Rating</label>

                <fieldset class="starability-slot">
                    <input type="radio" class="input-no-rate" name="review[rating]" value="0" checked />

                    <% for(let i = 1; i <= 5; i++) { %>
                        <input type="radio" id="rate<%= i %>" name="review[rating]" value="<%= i %>" />
                        <label for="rate<%= i %>">
                            <%= i %> star<%= i > 1 ? 's' : '' %>
                        </label>
                    <% } %>
                </fieldset>
            </div>

            <!-- Comment -->
            <div class="mb-3">
                <label class="form-label">Comments</label>
                <textarea name="review[comment]" 
                          class="form-control" 
                          required></textarea>

                <div class="invalid-feedback">
                    Please add some comments
                </div>
            </div>

            <button class="btn btn-outline-dark">Submit</button>
        </form>

        <hr>
    <% } %>


    <!-- Reviews List -->
    <h5 class="mb-3">All Reviews</h5>

    <div class="row">    
        <% for(let review of listing.reviews) { %>
            <div class="card col-5 ms-3 mb-3">    
                <div class="card-body">

                    <h5 class="card-title">
                        @<%= review.author?.username || "Anonymous" %>
                    </h5>

                    <p class="starability-result card-text" 
                       data-rating="<%= review.rating %>">
                        Rated: <%= review.rating %> stars
                    </p>

                    <p class="card-text text-muted">
                        <%= review.comment %>
                    </p>
                    
                    <% if(currentUser && review.author && currentUser._id.equals(review.author._id)) { %>
                        <form method="POST" 
                              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form> 
                    <% } %>

                </div>   
            </div>
        <% } %>
    </div>
</div>

<script src="/js/script.js"></script>